# Razzl API local development — copy to .env.local and fill in values.
# Production uses ECS task secrets (see Studio infra/terraform-dev).

NODE_ENV=development
PORT=8080
RAZZL_SERVICE=api
RAZZL_LOG_LEVEL=2

# Shared MySQL (same RDS as Studio)
RAZZL_AUTH_DB_HOST=
RAZZL_AUTH_DB_USER=
RAZZL_AUTH_DB_PASSWORD=
RAZZL_AUTH_DB_NAME=
# Set to "false" for local MySQL without SSL
RAZZL_AUTH_DB_SSL=true

# Pool tuning (optional)
# RAZZL_AUTH_DB_POOL_CONNECTION_LIMIT=10

# Public origin for OAuth redirects (local: http://localhost:8080)
RAZZL_PUBLIC_ORIGIN=http://localhost:8080

# Shopify app credentials (Partner Dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products
# SHOPIFY_API_VERSION=2024-10
# SHOPIFY_OAUTH_CALLBACK_PATH=/api/commerce/shopify/auth/callback

# AES-256-GCM key for platform token encryption (base64-encoded 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COMMERCE_TOKEN_ENCRYPTION_KEY=
